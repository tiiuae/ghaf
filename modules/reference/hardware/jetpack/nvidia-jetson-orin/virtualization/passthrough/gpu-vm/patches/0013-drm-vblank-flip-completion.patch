+/*
+ * dce passthrough: complete a committed flip once NV_DRM_FLIP_VBLANK_QUALIFY
+ * physical vblank callbacks have been observed since it was armed, so the new
+ * buffer has latched and the old buffer is free before userspace may reuse it
+ * (reuse-while-scanned is the tearing cause). See the flipVblank comment in
+ * nvidia-drm-priv.h.
+ *
+ * Qualification counts physical vblank CALLBACKS (vblankCbSeq -- NOT the DRM
+ * vblank counter, which the deferred callback increments under nvkms_lock and
+ * so reflects callback-processing order, not physical vblank count). Requiring
+ * NV_DRM_FLIP_VBLANK_QUALIFY callbacks after arming tolerates a late-kickoff
+ * scanout latch (the R5/window-channel completion signal is not usable as a
+ * per-flip contract under passthrough) at the cost of throughput (~30Hz).
+ *
+ * The completion handler runs from an NVKMS timer under nvkms_lock; it takes
+ * only event_lock and calls no NVKMS/KAPI path, so it cannot invert the commit
+ * lock order.
+ */
+
+/* Physical vblank callbacks required after arming before a flip completes. */
+#define NV_DRM_FLIP_VBLANK_QUALIFY 2
+
+void nv_drm_flip_vblank_init(struct nv_drm_device *nv_dev)
+{
+    NvU32 h, l;
+
+    for (h = 0; h < NVKMS_KAPI_MAX_HEADS; h++) {
+        nv_dev->flipVblankRefHeld[h] = NV_FALSE;
+        nv_dev->vblankCbSeq[h] = 0;
+        nv_dev->flipVblankGeneration[h] = 0;
+        for (l = 0; l < NVKMS_KAPI_LAYER_MAX; l++) {
+            nv_dev->flipVblank[h][l].armed = NV_FALSE;
+        }
+    }
+    atomic_set(&nv_dev->flipVblankEnabled, 1);
+}
+
+/*
+ * Invalidate all in-flight arms and release any held qualification vblank
+ * references without completing (teardown -- the device is going away).
+ * Bumping the generation guards a stale arm against a vblank-counter reset.
+ */
+void nv_drm_flip_vblank_invalidate(struct nv_drm_device *nv_dev)
+{
+    struct drm_device *dev = nv_dev->dev;
+    NvBool putHead[NVKMS_KAPI_MAX_HEADS];
+    unsigned long flags;
+    NvU32 h, l;
+
+    atomic_set(&nv_dev->flipVblankEnabled, 0);
+
+    spin_lock_irqsave(&dev->event_lock, flags);
+    for (h = 0; h < NVKMS_KAPI_MAX_HEADS; h++) {
+        nv_dev->flipVblankGeneration[h]++;
+        for (l = 0; l < NVKMS_KAPI_LAYER_MAX; l++) {
+            nv_dev->flipVblank[h][l].armed = NV_FALSE;
+        }
+        putHead[h] = nv_dev->flipVblankRefHeld[h];
+        nv_dev->flipVblankRefHeld[h] = NV_FALSE;
+    }
+    spin_unlock_irqrestore(&dev->event_lock, flags);
+
+    for (h = 0; h < NVKMS_KAPI_MAX_HEADS; h++) {
+        if (putHead[h]) {
+            struct nv_drm_crtc *nv_crtc = nv_drm_crtc_lookup(nv_dev, h);
+            if (nv_crtc != NULL) {
+                drm_crtc_vblank_put(&nv_crtc->base);
+            }
+        }
+    }
+}
+
+/*
+ * Called from nv_drm_crtc_vblank_callback (one call per physical vblank).
+ * Record this vblank and complete any arm that has now been observed across
+ * >= QUALIFY vblank callbacks since it was armed. The qualification vblank
+ * reference for the crtc is released once its last armed layer completes.
+ *
+ * Runs from an NVKMS timer under nvkms_lock; it takes only event_lock and
+ * calls no NVKMS/KAPI path, so it cannot invert the commit lock order.
+ */
+void nv_drm_flip_vblank_on_callback(struct nv_drm_device *nv_dev,
+                                    struct nv_drm_crtc *nv_crtc)
+{
+    struct drm_device *dev = nv_crtc->base.dev;
+    const NvU32 head = nv_crtc->head;
+    NvU32 doneLayers[NVKMS_KAPI_LAYER_MAX];
+    NvU32 nDone = 0;
+    NvBool putRef = NV_FALSE;
+    unsigned long flags;
+    NvU32 layer, i;
+
+    if (head >= NVKMS_KAPI_MAX_HEADS) {
+        return;
+    }
+
+    spin_lock_irqsave(&dev->event_lock, flags);
+    {
+        NvBool anyRemain = NV_FALSE;
+
+        nv_dev->vblankCbSeq[head]++;
+
+        for (layer = 0; layer < NVKMS_KAPI_LAYER_MAX; layer++) {
+            if (!nv_dev->flipVblank[head][layer].armed) {
+                continue;
+            }
+            /*
+             * Completes once NV_DRM_FLIP_VBLANK_QUALIFY physical vblank
+             * callbacks have been observed since this flip was armed
+             * (unsigned subtraction handles vblankCbSeq wrap).
+             */
+            if ((nv_dev->flipVblank[head][layer].generation ==
+                 nv_dev->flipVblankGeneration[head]) &&
+                ((nv_dev->vblankCbSeq[head] -
+                  nv_dev->flipVblank[head][layer].armCbSeq) >=
+                 NV_DRM_FLIP_VBLANK_QUALIFY)) {
+                nv_dev->flipVblank[head][layer].armed = NV_FALSE;
+                doneLayers[nDone++] = layer;
+            } else {
+                anyRemain = NV_TRUE;
+            }
+        }
+
+        if ((nDone > 0) && !anyRemain && nv_dev->flipVblankRefHeld[head]) {
+            nv_dev->flipVblankRefHeld[head] = NV_FALSE;
+            putRef = NV_TRUE;
+        }
+    }
+    spin_unlock_irqrestore(&dev->event_lock, flags);
+
+    for (i = 0; i < nDone; i++) {
+        nv_drm_handle_flip_event(nv_dev, head, doneLayers[i], true);
+    }
+    if (putRef) {
+        drm_crtc_vblank_put(&nv_crtc->base);
+    }
+}
+
+/*
+ * Arm a plane for vblank-qualified completion. Takes the crtc's qualification
+ * vblank reference on the first arm (enabling the vblank interrupt); returns
+ * NV_TRUE if a new reference was taken, so the caller can flush the vblank
+ * enable work once.
+ */
+/*
+ * Acquire the crtc's qualification vblank reference before any arm is
+ * published (fixing the race where a callback could see an armed plane before
+ * the vblank_get took effect). drm_crtc_vblank_get() is called first and its
+ * result checked -- it fails on an inactive/vblank-off crtc -- so refHeld is
+ * only set when a real reference is held. Returns NV_TRUE if this call took the
+ * reference (so the caller flushes the vblank-enable work once).
+ */
+static NvBool nv_drm_flip_vblank_acquire_ref(struct nv_drm_device *nv_dev,
+                                             struct nv_drm_crtc *nv_crtc)
+{
+    struct drm_device *dev = nv_crtc->base.dev;
+    const NvU32 head = nv_crtc->head;
+    NvBool took = NV_FALSE;
+    unsigned long flags;
+
+    if (head >= NVKMS_KAPI_MAX_HEADS) {
+        return NV_FALSE;
+    }
+    if (drm_crtc_vblank_get(&nv_crtc->base) != 0) {
+        return NV_FALSE;
+    }
+
+    spin_lock_irqsave(&dev->event_lock, flags);
+    if (atomic_read(&nv_dev->flipVblankEnabled) &&
+        !nv_dev->flipVblankRefHeld[head]) {
+        nv_dev->flipVblankRefHeld[head] = NV_TRUE;
+        took = NV_TRUE;
+    }
+    spin_unlock_irqrestore(&dev->event_lock, flags);
+
+    if (!took) {
+        /* Already held, or disabled between get and publish: undo the get. */
+        drm_crtc_vblank_put(&nv_crtc->base);
+    }
+    return took;
+}
+
+/*
+ * Publish an arm for a plane. The crtc's vblank reference must already be held
+ * (nv_drm_flip_vblank_acquire_ref). Only arms while enabled and a reference is
+ * held, both re-checked under event_lock so a concurrent invalidate cannot be
+ * raced. Returns NV_TRUE if the plane was armed.
+ */
+static NvBool nv_drm_flip_vblank_arm(struct nv_drm_device *nv_dev,
+                                     struct nv_drm_crtc *nv_crtc, NvU32 layer)
+{
+    struct drm_device *dev = nv_crtc->base.dev;
+    const NvU32 head = nv_crtc->head;
+    NvBool armed = NV_FALSE;
+    unsigned long flags;
+
+    if ((head >= NVKMS_KAPI_MAX_HEADS) || (layer >= NVKMS_KAPI_LAYER_MAX)) {
+        return NV_FALSE;
+    }
+
+    spin_lock_irqsave(&dev->event_lock, flags);
+    if (atomic_read(&nv_dev->flipVblankEnabled) &&
+        nv_dev->flipVblankRefHeld[head]) {
+        nv_dev->flipVblank[head][layer].armed = NV_TRUE;
+        nv_dev->flipVblank[head][layer].armCbSeq =
+            nv_dev->vblankCbSeq[head];
+        nv_dev->flipVblank[head][layer].generation =
+            nv_dev->flipVblankGeneration[head];
+        armed = NV_TRUE;
+    }
+    spin_unlock_irqrestore(&dev->event_lock, flags);
+
+    return armed;
+}
+
+/*
+ * Invalidate this head's in-flight arms on a modeset (bumping only this
+ * head's generation, so arms on other heads are untouched), and drop this
+ * crtc's qualification vblank reference if held. A modeset changes the vblank
+ * timing contract for this crtc, so any arm snapshotted against the old
+ * vblankCbSeq is stale; the generation bump makes on_callback skip those
+ * stale arms (the blocking commit's own new flip re-arms and completes). A
+ * modeset is rare.
+ */
+void nv_drm_flip_vblank_reset_on_modeset(struct nv_drm_device *nv_dev,
+                                         struct nv_drm_crtc *nv_crtc)
+{
+    struct drm_device *dev = nv_crtc->base.dev;
+    const NvU32 head = nv_crtc->head;
+    NvBool putRef = NV_FALSE;
+    unsigned long flags;
+    NvU32 layer;
+
+    if (head >= NVKMS_KAPI_MAX_HEADS) {
+        return;
+    }
+
+    spin_lock_irqsave(&dev->event_lock, flags);
+    nv_dev->flipVblankGeneration[head]++;
+    for (layer = 0; layer < NVKMS_KAPI_LAYER_MAX; layer++) {
+        nv_dev->flipVblank[head][layer].armed = NV_FALSE;
+    }
+    if (nv_dev->flipVblankRefHeld[head]) {
+        nv_dev->flipVblankRefHeld[head] = NV_FALSE;
+        putRef = NV_TRUE;
+    }
+    spin_unlock_irqrestore(&dev->event_lock, flags);
+
+    if (putRef) {
+        drm_crtc_vblank_put(&nv_crtc->base);
+    }
+}
+
+/* True if the crtc has any plane with a pending flip in its flip_list. */
+static bool nv_drm_crtc_any_pending_flip(struct nv_drm_crtc *nv_crtc)
+{
+    struct drm_device *dev = nv_crtc->base.dev;
+    struct nv_drm_flip *nv_flip_pos;
+    bool pending = false;
+
+    spin_lock(&dev->event_lock);
+    list_for_each_entry(nv_flip_pos, &nv_crtc->flip_list, list_entry) {
+        if (nv_flip_pos->pending_events_plane_mask != 0) {
+            pending = true;
+            break;
+        }
+    }
+    spin_unlock(&dev->event_lock);
+
+    return pending;
+}
+
+static bool nv_drm_plane_has_pending_flip(struct nv_drm_crtc *nv_crtc,
+                                          uint32_t plane_mask)
+{
+    struct drm_device *dev = nv_crtc->base.dev;
+    struct nv_drm_flip *nv_flip_pos;
+    bool pending = false;
+
+    spin_lock(&dev->event_lock);
+    list_for_each_entry(nv_flip_pos, &nv_crtc->flip_list, list_entry) {
+        if (nv_flip_pos->pending_events_plane_mask & plane_mask) {
+            pending = true;
+            break;
+        }
+    }
+    spin_unlock(&dev->event_lock);
+
+    return pending;
+}
