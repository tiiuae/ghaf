+#pragma once
+
+#include <modules/ghaf_audio_control/app_list.hpp>
+#include <modules/ghaf_audio_control/iaudio_control_backend.hpp>
+
+#include <AModule.hpp>
+
+#include <glibmm/refptr.h>
+#include <gtkmm/menubutton.h>
+#include <gtkmm/popover.h>
+#include <gtkmm/separator.h>
+#include <gtkmm/stacksidebar.h>
+
+namespace waybar::modules::ghaf {
+
+class AudioControl : public AModule
+{
+private:
+  template <class ExternalIndex>
+  class IndexMapper
+  {
+  public:
+    using InternalIndex = size_t;
+
+    InternalIndex get(ExternalIndex extIndex)
+    {
+      if (const auto internalIndexIter = m_extToInt.find(extIndex); internalIndexIter != m_extToInt.end())
+        return internalIndexIter->second;
+
+      const auto newIntIndex = m_intToExt.size();
+
+      m_intToExt.push_back(extIndex);
+      m_extToInt[extIndex] = newIntIndex;
+
+      return newIntIndex;
+    }
+
+   private:
+    std::map<ExternalIndex, InternalIndex> m_extToInt;
+    std::vector<ExternalIndex> m_intToExt;
+  };
+
+public:
+  static inline std::string ModuleName = "ghaf-audio-control";
+
+  AudioControl(const std::string& id, const Json::Value&);
+  ~AudioControl() override = default;
+
+  void update() override;
+
+  void onPulseSinksChanged(IAudioControlBackend::EventType eventType, IAudioControlBackend::Sinks::IndexT extIndex, IAudioControlBackend::Sinks::PtrT sink);
+  void onPulseSourcesChanged(IAudioControlBackend::EventType eventType, IAudioControlBackend::Sinks::IndexT extIndex, IAudioControlBackend::Sources::PtrT source);
+
+private:
+  StackWithSidebar m_box;
+  Gtk::Popover m_popover;
+  Gtk::MenuButton m_menuButton;
+
+  IndexMapper<IAudioControlBackend::Sinks::IndexT> m_sinkIndexMapper;
+  IndexMapper<IAudioControlBackend::Sources::IndexT> m_sourceIndexMapper;
+
+  std::unique_ptr<IAudioControlBackend> m_audioControl;
+
+  std::vector<sigc::connection> m_connections;
+};
+
+}  // namespace waybar::modules::ghaf
diff --git a/include/modules/ghaf_audio_control/iaudio_control_backend.hpp b/include/modules/ghaf_audio_control/iaudio_control_backend.hpp
new file mode 100644
index 00000000..ca1b02ef
--- /dev/null
+++ b/include/modules/ghaf_audio_control/iaudio_control_backend.hpp
@@ -0,0 +1,163 @@
+#pragma once
+
+#include <functional>
+#include <map>
+#include <memory>
+#include <optional>
+
+#include <sigc++/signal.h>
+
+namespace waybar::modules::ghaf {
+
+template <typename T>
+concept NumericType= std::unsigned_integral<T> || std::floating_point<T>;
+
+class IAudioControlBackend
+{
+public:
+  enum class EventType
+  {
+    Add,
+    Update,
+    Delete
+  };
+
+  template <class Index, class T>
+  class SignalMap final
+  {
+  public:
+    using IndexT = Index;
+    using PtrT = std::shared_ptr<T>;
+
+  private:
+    using MapType = std::map<Index, PtrT>;
+
+  public:
+    using Iter = MapType::iterator;
+    using OnChangeSignal = sigc::signal<void(EventType, IndexT, PtrT)>;
+
+  SignalMap() = default;
+
+  void add(const Index& key, PtrT&& data)
+  {
+    auto result = m_map.emplace(key, std::forward<PtrT&&>(data));
+    auto iter = result.first;
+
+    m_onChange(EventType::Add, iter->first, iter->second);
+  }
+
+  std::optional<Iter> findByKey(const Index& key)
+  {
+    if (auto iter = m_map.find(key); iter != m_map.end())
+      return iter;
+
+    return std::nullopt;
+  }
+
+  std::vector<Iter> findByPredicate(const std::function<bool(const T&)>& predicate)
+  {
+    std::vector<Iter> iterators;
+
+    for (Iter it = m_map.begin(); it != m_map.end(); ++it)
+    {
+      if (const PtrT ptr = it->second; predicate(*ptr))
+        iterators.push_back(it);
+    }
+
+    return iterators;
+  }
+
+  void update(Iter iter, const std::function<void(T&)>& updateFunction)
+  {
+    PtrT ptr = iter->second;
+
+    updateFunction(*ptr);
+    m_onChange(EventType::Update, iter->first, ptr);
+  }
+
+  void remove(Iter iter)
+  {
+    std::ignore = m_map.erase(iter->first);
+    m_onChange(EventType::Delete, iter->first, nullptr);
+  }
+
+  OnChangeSignal onChange() const
+  { return m_onChange; }
+
+  private:
+    MapType m_map;
+    OnChangeSignal m_onChange;
+ };
+
+  class IDevice
+  {
+   public:
+    using Ptr = std::shared_ptr<IDevice>;
+
+    class Volume
+    {
+    public:
+      using InternalT = uint8_t;
+
+      static constexpr InternalT Min = 0;
+      static constexpr InternalT Max = 100;
+
+      Volume(NumericType auto value)
+        : m_volume(trunkate(value))
+      { }
+
+      Volume& operator = (NumericType auto value) noexcept
+      { m_volume = trunkate(value); return *this; }
+
+      operator InternalT () const noexcept
+      { return m_volume; }
+
+    private:
+      InternalT trunkate(NumericType auto value) const noexcept
+      {
+        if (value < Min)
+          return Min;
+
+        if (value > Max)
+          return Max;
+
+        return value;
+      }
+
+      InternalT m_volume;
+    };
+
+    virtual ~IDevice() = default;
+
+    virtual bool operator == (const IDevice& other) const = 0;
+
+    virtual std::string getName() const = 0;
+
+    virtual bool isEnabled() const = 0;
+
+    virtual bool isMuted() const = 0;
+    virtual void setMuted(bool mute) = 0;
+
+    virtual Volume getVolume() const = 0;
+    virtual void setVolume(Volume volume) = 0;
+
+    virtual std::string toString() const = 0;
+  };
+
+  class ISink : public IDevice
+  { };
+
+  class ISource : public IDevice
+  { };
+
+  using Index = uint64_t;
+  using Sinks = SignalMap<Index, ISink>;
+  using Sources = SignalMap<Index, ISource>;
+
+  virtual ~IAudioControlBackend() = default;
+
+  virtual Sinks::OnChangeSignal onSinksChanged() const = 0;
+  virtual Sources::OnChangeSignal onSourcesChanged() const = 0;
+};
+
+}  // namespace waybar::modules::ghaf
