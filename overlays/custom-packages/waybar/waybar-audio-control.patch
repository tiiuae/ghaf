+class GeneralDeviceImpl final
+{
+public:
+  GeneralDeviceImpl(const pa_sink_info& info, pa_context& context):
+    m_index(info.index),
+    m_cardIndex(info.card),
+    m_name(info.name),
+    m_description(info.description),
+    m_context(context),
+    m_channel_map(info.channel_map),
+    m_volume(info.volume),
+    m_isMuted(static_cast<bool>(info.mute))
+  { }
+
+  GeneralDeviceImpl(const pa_source_info& info, pa_context& context):
+    m_index(info.index),
+    m_cardIndex(info.card),
+    m_name(info.name),
+    m_description(info.description),
+    m_context(context),
+    m_channel_map(info.channel_map),
+    m_volume(info.volume),
+    m_isMuted(static_cast<bool>(info.mute))
+  { }
+
+  bool operator == (const GeneralDeviceImpl& other) const
+  { return m_index == other.m_index; }
+
+  uint32_t getIndex() const noexcept
+  { return m_index; }
+
+  uint32_t getCardIndex() const noexcept
+  { return m_cardIndex; }
+
+  bool isEnabled() const noexcept
+  { return m_isEnabled; }
+
+  bool isMuted() const
+  { const std::lock_guard l{m_mutex}; return m_isMuted; }
+
+  IAudioControlBackend::IDevice::Volume getVolume() const
+  { return PulseVolumeToVolume(getPulseVolume()); }
+
+  pa_volume_t getPulseVolume() const
+  { const std::lock_guard l{m_mutex}; return m_volume.values[0]; }
+
+  pa_cvolume getPulseChannelVolume() const noexcept
+  { const std::lock_guard l{m_mutex}; return m_volume; }
+
+  std::string getName() const
+  { const std::lock_guard l{m_mutex}; return fmt::format("#{}. {}", m_index, m_description); }
+
+  sigc::signal<void()> onChanged() const
+  { return m_onChanged; }
+
+  std::string toString() const
+  {
+    const std::lock_guard l{m_mutex};
+    return fmt::format("index: {}, name: {}, volume: {}, isMuted: {}", m_index, m_description, m_volume.values[0], m_isMuted);
+  }
+
+  std::string getDescription() const
+  { const std::lock_guard l{m_mutex}; return m_description; }
+
+  pa_context& getContext() const noexcept
+  { return m_context; }
+
+  void update(const pa_sink_info& info)
+  {
+    {
+      const std::lock_guard l{m_mutex};
+
+      m_cardIndex = info.card;
+      m_name = info.name;
+      m_description = info.description;
+      m_channel_map = info.channel_map;
+      m_volume = info.volume;
+      m_isMuted = static_cast<bool>(info.mute);
+    }
+
+    m_onChanged();
+  }
+
+  void update(const pa_source_info& info)
+  {
+    {
+      const std::lock_guard l{m_mutex};
+
+      m_cardIndex = info.card;
+      m_name = info.name;
+      m_description = info.description;
+      m_channel_map = info.channel_map;
+      m_volume = info.volume;
+      m_isMuted = static_cast<bool>(info.mute);
+    }
+
+    m_onChanged();
+  }
+
+  void update(const pa_card_info& info)
+  {
+    {
+      const std::lock_guard l{m_mutex};
+
+      m_isEnabled = false;
+
+      if (m_cardIndex == info.index)
+      {
+        for (size_t i = 0; i < info.n_ports; ++i)
+        {
+          pa_card_port_info const* port = info.ports[i];
+
+          if (m_description == port->description && port->available == PA_PORT_AVAILABLE_YES)
+          {
+            m_isEnabled = true;
+            break;
+          }
+        }
+      }
+    }
+
+    m_onChanged();
+  }
+
+private:
+  const uint32_t m_index;
+  uint32_t m_cardIndex;
+
+  bool m_isEnabled = false;
+  std::string m_name;
+  std::string m_description;
+
+  pa_context& m_context;
+
+  pa_channel_map m_channel_map;
+  pa_cvolume m_volume;
+  bool m_isMuted;
+
+  mutable std::mutex m_mutex;
+  sigc::signal<void()> m_onChanged;
+};
+
+class Sink final : public IAudioControlBackend::ISink
+{
+public:
+  Sink(const pa_sink_info& info, pa_context& context):
+    m_device(info, context)
+  { }
+
+  bool operator == (const IDevice& other) const override
+  {
+    if (const Sink* otherSink = dynamic_cast<const Sink*>(&other))
+      return m_device == otherSink->m_device;
+
+    return false;
+  }
+
+  std::string getName() const override
+  { return m_device.getName(); }
+
+  bool isEnabled() const override
+  { return m_device.isEnabled(); }
+
+  bool isMuted() const override
+  { return m_device.isMuted(); }
+
+  void setMuted(bool mute) override
+  { ExecutePulseFunc(pa_context_set_sink_mute_by_index, &m_device.getContext(), m_device.getIndex(), mute, nullptr, nullptr); }
+
+  Volume getVolume() const override
+  { return m_device.getVolume(); }
+
+  void setVolume(Volume volume) override
+  {
+    pa_cvolume paChannelVolume;
+    std::ignore = pa_cvolume_set(&paChannelVolume, m_device.getPulseChannelVolume().channels, VolumeToPulseVolume(volume));
+
+    ExecutePulseFunc(pa_context_set_sink_volume_by_index, &m_device.getContext(), m_device.getIndex(), &paChannelVolume, nullptr, nullptr);
+  }
+
+  uint32_t getCardIndex() const noexcept
+  { return m_device.getCardIndex(); }
+
+  std::string toString() const override
+  { return fmt::format("PulseSink: [ {} ]", m_device.toString()); }
+
+  std::string getDescription() const
+  { return m_device.getDescription(); }
+
+  void update(const pa_sink_info& info)
+  { m_device.update(info); }
+
+  void update(const pa_card_info& info)
+  { m_device.update(info); }
+
+private:
+  GeneralDeviceImpl m_device;
+};
+
+class Source final : public IAudioControlBackend::ISource
+{
+public:
+  Source(const pa_source_info& info, pa_context& context):
+    m_device(info, context)
+  { }
+
+  bool operator == (const IDevice& other) const override
+  {
+    if (const auto* otherSource = dynamic_cast<const Source*>(&other))
+      return m_device == otherSource->m_device;
+
+    return false;
+  }
+
+  std::string getName() const override
+  { return m_device.getName(); }
+
+  bool isEnabled() const override
+  { return m_device.isEnabled(); }
+
+  bool isMuted() const override
+  { return m_device.isMuted(); }
+
+  void setMuted(bool mute) override
+  { ExecutePulseFunc(pa_context_set_sink_mute_by_index, &m_device.getContext(), m_device.getIndex(), mute, nullptr, nullptr); }
+
+  Volume getVolume() const override
+  { return m_device.getVolume(); }
+
+  void setVolume(Volume volume) override
+  {
+    pa_cvolume paChannelVolume;
+    std::ignore = pa_cvolume_set(&paChannelVolume, m_device.getPulseChannelVolume().channels, VolumeToPulseVolume(volume));
+
+    ExecutePulseFunc(pa_context_set_source_volume_by_index, &m_device.getContext(), m_device.getIndex(), &paChannelVolume, nullptr, nullptr);
+  }
+
+  std::string toString() const override
+  { return fmt::format("PulseSource: [ {} ]", m_device.toString()); }
+
+  std::string getDescription() const
+  { return m_device.getDescription(); }
+
+  uint32_t getCardIndex() const noexcept
+  { return m_device.getCardIndex(); }
+
+  void update(const pa_source_info& info)
+  { m_device.update(info); }
+
+  void update(const pa_card_info& info)
+  { m_device.update(info); }
+
+private:
+  GeneralDeviceImpl m_device;
+};
+
+}
+
+PulseAudioControlBackend::PulseAudioControlBackend()
+  : m_mainloop(pa_threaded_mainloop_new())
+{
+  if (m_mainloop == nullptr)
+    throw std::runtime_error("pa_threaded_mainloop_new() failed.");
+
+  pa_threaded_mainloop_lock(m_mainloop);
+  util::ScopeGuard guard{[this]{ pa_threaded_mainloop_unlock(m_mainloop);} };
+
+  m_mainloopApi = pa_threaded_mainloop_get_api(m_mainloop);
+
+  connectContext();
+
+  if (pa_threaded_mainloop_start(m_mainloop) < 0)
+    throw std::runtime_error("pa_mainloop_run() failed.");
+}
+
+PulseAudioControlBackend::~PulseAudioControlBackend()
+{
+  if (m_context != nullptr)
+    pa_context_disconnect(m_context);
+
+  if (m_mainloop != nullptr)
+  {
+    if (m_mainloopApi != nullptr)
+      m_mainloopApi->quit(m_mainloopApi, 0);
+
+    pa_threaded_mainloop_stop(m_mainloop);
+    pa_threaded_mainloop_free(m_mainloop);
+  }
+}
+
+void PulseAudioControlBackend::onSinkInfo(const pa_sink_info &info)
+{
+  const Index index = info.index;
+
+  if (auto sinkIt = m_sinks.findByKey(index))
+  {
+    const ISink& sink = *sinkIt.value()->second;
+    spdlog::debug("Updating... Before: {}", sink.toString());
+
+    m_sinks.update(*sinkIt, [&info](ISink& sink)
+    { dynamic_cast<Sink&>(sink).update(info); });
+
+    spdlog::debug("Updating... After: {}", sink.toString());
+  }
+  else
+  {
+    m_sinks.add(index, std::make_shared<Sink>(info, *m_context));
+  }
+}
+
+void PulseAudioControlBackend::deleteSink(Sinks::IndexT index)
+{
+  if (auto sinkIt = m_sinks.findByKey(index))
+  {
+    spdlog::debug("PulseAudioControlBackend::deleteSink: delete sink with id: {}", index);
+    m_sinks.remove(*sinkIt);
+  }
+  else
+    spdlog::error("PulseAudioControlBackend::deleteSink: no sink with id: {}", index);
+}
+
+void PulseAudioControlBackend::onSourceInfo(const pa_source_info &info)
+{
+  const Index index = info.index;
+
+  if (auto sourceIt = m_sources.findByKey(index))
+  {
+    m_sources.update(*sourceIt, [&info](ISource& source)
+    { dynamic_cast<Source&>(source).update(info); });
+  }
+  else
+  { m_sources.add(index, std::make_shared<Source>(info, *m_context)); }
+}
+
+void PulseAudioControlBackend::deleteSource(Sources::IndexT index)
+{
+  if (auto sourceIt = m_sources.findByKey(index))
+  {
+    spdlog::debug("PulseAudioControlBackend::deleteSource: delete source with id: {}", index);
+    m_sources.remove(*sourceIt);
+  }
+  else
+    spdlog::error("PulseAudioControlBackend::deleteSource: no source with id: {}", index);
+}
+
+void PulseAudioControlBackend::subscribeCb(pa_context *context, pa_subscription_event_type_t type, uint32_t index, void *data)
+{
+  auto *self = static_cast<PulseAudioControlBackend*>(data);
+  const bool needRemove = (type & pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_TYPE_MASK) == pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_REMOVE;
+  const pa_subscription_event_type eventType = static_cast<pa_subscription_event_type>(type & pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_FACILITY_MASK);
+
+  switch (eventType)
+  {
+    case pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_SERVER:
+      ExecutePulseFunc(pa_context_get_server_info, context, serverInfoCb, data);
+      break;
+
+    case pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_SINK:
+      if (needRemove) self->deleteSink(index);
+      else ExecutePulseFunc(pa_context_get_sink_info_by_index, context, index, sinkInfoCb, data);
+
+      break;
+
+    case pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_SINK_INPUT:
+      ExecutePulseFunc(pa_context_get_sink_info_list, context, sinkInfoCb, data);
+      break;
+
+    case pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_SOURCE:
+      if (needRemove) self->deleteSource(index);
+      else ExecutePulseFunc(pa_context_get_source_info_by_index, context, index, sourceInfoCb, data);
+
+      break;
+
+    case pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_SOURCE_OUTPUT:
+      ExecutePulseFunc(pa_context_get_source_info_list, context, sourceInfoCb, data);
+      break;
+
+    case pa_subscription_event_type::PA_SUBSCRIPTION_EVENT_CARD:
+      ExecutePulseFunc(pa_context_get_card_info_by_index, context, index, cardInfoCb, data);
+      break;
+
+    default:
+      spdlog::error("subscribeCb: unknown eventType: {0}", static_cast<int>(eventType));
+      break;
+  };
+}
+
+void PulseAudioControlBackend::contextStateCb(pa_context *context, void *data)
+{
+  auto *self = static_cast<PulseAudioControlBackend*>(data);
+
+  switch (const auto state = pa_context_get_state(context))
+  {
+    case pa_context_state_t::PA_CONTEXT_TERMINATED:
+      self->m_mainloopApi->quit(self->m_mainloopApi, 0);
+      break;
+
+    case pa_context_state_t::PA_CONTEXT_READY:
+      ExecutePulseFunc(pa_context_get_server_info,context, serverInfoCb, data);
+      pa_context_set_subscribe_callback(context, subscribeCb, data);
+      ExecutePulseFunc(pa_context_subscribe, context, SubscriptionMask, nullptr, nullptr);
+      break;
+
+    case pa_context_state_t::PA_CONTEXT_FAILED:
+      if (self->m_context != nullptr)
+        pa_context_disconnect(self->m_context);
+
+      self->connectContext();
+      break;
+
+    case pa_context_state_t::PA_CONTEXT_CONNECTING:
+    case pa_context_state_t::PA_CONTEXT_AUTHORIZING:
+    case pa_context_state_t::PA_CONTEXT_SETTING_NAME:
+      break;
+
+    default:
+      spdlog::error("contextStateCb: unknown state: {0}", static_cast<int>(state));
+      break;
+  }
+}
+
+void PulseAudioControlBackend::sinkInfoCb(pa_context *context, const pa_sink_info *info, int eol, void *data)
+{
+  if (!PulseCallbackCheck(context, eol, __FUNCTION__) || info == nullptr)
+    return;
+
+  static_cast<PulseAudioControlBackend*>(data)->onSinkInfo(*info);
+}
+
+void PulseAudioControlBackend::sourceInfoCb(pa_context *context, const pa_source_info *info, int eol, void *data)
+{
+  if (!PulseCallbackCheck(context, eol, __FUNCTION__) || info == nullptr)
+    return;
+
+  static_cast<PulseAudioControlBackend*>(data)->onSourceInfo(*info);
+}
+
+void PulseAudioControlBackend::serverInfoCb(pa_context *context, const pa_server_info *info, void *data)
+{
+  if (info == nullptr)
+    return;
+
+  auto *self = static_cast<PulseAudioControlBackend*>(data);
+  self->m_defaultSinkName = info->default_sink_name;
+  self->m_defaultSourceName = info->default_source_name;
+
+  ExecutePulseFunc(pa_context_get_sink_info_list, context, sinkInfoCb, data);
+  ExecutePulseFunc(pa_context_get_source_info_list, context, sourceInfoCb, data);
+  ExecutePulseFunc(pa_context_get_card_info_list, context, cardInfoCb, data);
+}
+
+
+void PulseAudioControlBackend::cardInfoCb(pa_context *context, const pa_card_info *info, int eol, void *data)
+{
+  if (!PulseCallbackCheck(context, eol, __FUNCTION__))
+    return;
+
+  if (info == nullptr)
+    return;
+
+  auto *self = static_cast<PulseAudioControlBackend*>(data);
+
+  auto sinkPredicate = [&info](const ISink& sink) -> bool
+  { return dynamic_cast<const Sink&>(sink).getCardIndex() == info->index; };
+
+  for (auto it : self->m_sinks.findByPredicate(sinkPredicate))
+  {
+    self->m_sinks.update(it, [&info](ISink& sink)
+    { dynamic_cast<Sink&>(sink).update(*info); });
+  }
+
+  auto sourcePredicate = [&info](const ISource& source)
+  { return dynamic_cast<const Source&>(source).getCardIndex() == info->index; };
+
+  for (auto it : self->m_sources.findByPredicate(sourcePredicate))
+  {
+    self->m_sources.update(it, [&info](ISource& source)
+    { dynamic_cast<Source&>(source).update(*info); });
+  }
+}
+
+void PulseAudioControlBackend::connectContext()
+{
+  m_context = pa_context_new(m_mainloopApi, "WaybarGhafAudioControl");
+
+  if (m_context == nullptr)
+    throw std::runtime_error("pa_context_new() failed.");
+
+  pa_context_set_state_callback(m_context, contextStateCb, this);
+
+  if (pa_context_connect(m_context, nullptr, PA_CONTEXT_NOFAIL, nullptr) < 0)
+    throw std::runtime_error(fmt::format("pa_context_connect() failed: {}", pa_strerror(pa_context_errno(m_context))));
+}
