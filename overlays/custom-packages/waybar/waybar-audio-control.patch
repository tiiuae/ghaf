+AudioControl::AudioControl(const std::string& id, const Json::Value& config)
+  : AModule(config, ModuleName, id)
+{
+  try
+  {
+    m_audioControl = std::make_unique<PulseAudioControlBackend>();
+
+    m_popover.add(m_box);
+    m_box.show_all();
+
+    m_connections =
+    {
+      m_audioControl->onSinksChanged().connect(sigc::mem_fun(*this, &AudioControl::onPulseSinksChanged)),
+      m_audioControl->onSourcesChanged().connect(sigc::mem_fun(*this, &AudioControl::onPulseSourcesChanged))
+    };
+  }
+  catch(const std::exception& ex)
+  {
+    auto *errorLabel = Gtk::make_managed<Gtk::Label>();
+    errorLabel->set_label(ex.what());
+
+    m_popover.add(*errorLabel);
+    errorLabel->show_all();
+  }
+
+  m_menuButton.set_label("Audio Control");
+  m_menuButton.set_popover(m_popover);
+
+  event_box_.add(m_menuButton);
+  event_box_.add_label("EventBoxLabel");
