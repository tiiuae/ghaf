+void AudioControl::onPulseSinksChanged(IAudioControlBackend::EventType eventType, IAudioControlBackend::Sinks::IndexT extIndex, IAudioControlBackend::Sinks::PtrT sink)
+{
+  const auto intIndex = m_sinkIndexMapper.get(extIndex);
+
+  switch (eventType)
+  {
+    case IAudioControlBackend::EventType::Add:
+      spdlog::debug("onPulseSinksChanged: ADD sink with intIndex: {0}, sink: {1}", intIndex, sink->toString());
+      m_box.addApp(intIndex, std::move(sink), nullptr);
+      break;
+
+    case IAudioControlBackend::EventType::Update:
+      spdlog::debug("onPulseSinksChanged: UPDATE sink with intIndex: {0}, sink: {1}", intIndex, sink->toString());
+      m_box.updateApp(intIndex, std::move(sink), nullptr);
+      break;
+
+    case IAudioControlBackend::EventType::Delete:
+      spdlog::debug("onPulseSinksChanged: DELETE sink with intIndex: {0}", intIndex);
+      m_box.deleteApp(intIndex);
+      break;
+  }
+
+  update();
+}
+
+void AudioControl::onPulseSourcesChanged(IAudioControlBackend::EventType eventType,
+                                                IAudioControlBackend::Sources::IndexT extIndex,
+                                                IAudioControlBackend::Sources::PtrT source)
+{
+  //const auto intIndex = m_sourceIndexMapper.get(extIndex); // Fix after we have by App sinks and sources
+  const auto intIndex = m_sinkIndexMapper.get(extIndex + 100);
+
+  switch (eventType)
+  {
+    case IAudioControlBackend::EventType::Add:
+      spdlog::debug("onPulseSourcesChanged: ADD source with intIndex: {0}, source: {1}", intIndex, source->toString());
+      m_box.addApp(intIndex, nullptr, std::move(source));
+      break;
+
+    case IAudioControlBackend::EventType::Update:
+      spdlog::debug("onPulseSourcesChanged: UPDATE source with intIndex: {0}, source: {1}", intIndex, source->toString());
+      m_box.updateApp(intIndex, nullptr, std::move(source));
+      break;
+
+    case IAudioControlBackend::EventType::Delete:
+      spdlog::debug("onPulseSourcesChanged: DELETE source with intIndex: {0}", intIndex);
+      m_box.deleteApp(intIndex);
+      break;
+  }
+
+  update();
+}
