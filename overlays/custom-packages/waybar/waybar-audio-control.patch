+  Gtk::PositionType GetPositionSetting(const Json::Value& config) noexcept
+  {
+    try
+    {
+      const auto& position = config["position"];
+
+      if (position.empty())
+        throw std::runtime_error(": no 'position' attribute has been set for ghaf-audio-control, apply default...");
+
+      if (position == "bottom")
+        return Gtk::PositionType::POS_BOTTOM;
+
+      if (position == "top")
+        return Gtk::PositionType::POS_TOP;
+
+      if (position == "left")
+        return Gtk::PositionType::POS_LEFT;
+
+      if (position == "right")
+        return Gtk::PositionType::POS_RIGHT;
+
+      throw std::runtime_error{std::format("Unknown widget position type: {}", position.asString())};
+    }
+    catch (const std::exception& ex)
+    {
+      spdlog::error("GetPositionSetting: {0}. Apply default one -- TOP", ex.what());
+      return Gtk::PositionType::POS_TOP;
+    }
+  }
+
+}
