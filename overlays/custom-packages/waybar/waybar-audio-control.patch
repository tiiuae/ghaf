+pa_volume_t VolumeToPulseVolume(IAudioControlBackend::IDevice::Volume volume)
+{
+  const double coeff = volume / static_cast<double>(IAudioControlBackend::IDevice::Volume::Max);
+  return PA_VOLUME_NORM * coeff;
+}
+
+IAudioControlBackend::IDevice::Volume PulseVolumeToVolume(pa_volume_t pulseVolume)
+{ return (pulseVolume * IAudioControlBackend::IDevice::Volume::Max) / PA_VOLUME_NORM; }
+
+bool PulseCallbackCheck(const pa_context* context, int eol, std::string_view callbackName)
+{
+  if (context == nullptr)
+  {
+    spdlog::error("pulseCallbackCheck: callback: {0} context == nullptr", callbackName);
+    return false;
+  }
+
+  if (eol == 0)
+    return true;
+
+  const auto error = pa_context_errno(context);
+
+  if (error == PA_ERR_NOENTITY || error == PA_OK)
+    return true;
+
+  spdlog::error("pulseCallbackCheck: callback: {0} failed with error: {1}", callbackName, pa_strerror(error));
+
+  return false;
+}
+
+#define DEBUG 1
+
+template <class Fx, class ... ArgsT>
+void ExecutePulseFuncPrivate(Fx fx, ArgsT... args)
+{
+  if (pa_operation* operation = fx(args...))
+    pa_operation_unref(operation);
+  else
+    spdlog::error("Pulseaudio function failed");
+}
+
+#if defined(DEBUG)
+  #define ExecutePulseFunc(FX, ARGS...) { spdlog::debug("ExecutePulseFunc: {0}", #FX); ExecutePulseFuncPrivate(FX, ARGS); }
+#else
+  template <class Fx, class ... ArgsT>
+  void ExecutePulseFuncPrivate(Fx fx, ArgsT&&... args)
+  { ExecutePulseFuncPrivate(fx, args...); }
+#endif
