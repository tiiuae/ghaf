diff --git a/Makefile b/Makefile
index 5a3d1d9d6..6a9fef1de 100644
--- a/Makefile
+++ b/Makefile
@@ -233,6 +233,17 @@ ifneq ($(GOVERBOSE),)
 	go_flags += -v
 endif
 
+GO_TAGS := $(GO_TAGS)
+
+ifeq ($(WITH_PLUGINS),1)
+    GO_TAGS += withplugins
+endif
+
+# Append the final computed tags to go_flags
+ifneq ($(strip $(GO_TAGS)),)
+    go_flags += -tags="$(strip $(GO_TAGS))"
+endif
+
 # Determine the ldflags passed to the go linker. The git tag and hash will be
 # provided to the linker unless the git status is dirty.
 go_ldflags := -s -w
diff --git a/pkg/agent/catalog/keymanager.go b/pkg/agent/catalog/keymanager.go
index 28d12e4c0..237bb0b7b 100644
